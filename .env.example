# Shared env vars for local, Railway, or Vercel.
# Copy to .env and fill in values. Never commit .env.

# Required in production (Railway / Vercel)
# On Vercel: Project Settings → Environment Variables (Production + Preview).
# Missing SECRET_KEY crashes the serverless function (FUNCTION_INVOCATION_FAILED).
SECRET_KEY=
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
PRODUCTION=1
FLASK_ENV=production

# Postgres strongly recommended on Railway/Vercel (SQLite is fine locally).
# On Vercel without DATABASE_URL, SQLite uses /tmp (ephemeral across cold starts).
# Railway/Vercel may inject postgres:// — the app rewrites it to postgresql://
DATABASE_URL=

# Optional: raise/lower hosted-style limits when self-hosting
# FREE_TIER_LIMIT=1000

# Optional: enable FastAPI interactive docs when running api/ locally
# API_DOCS_ENABLED=1
